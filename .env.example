# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key        # sensitive — never expose to client

# ── Site URL ──────────────────────────────────────────────────────────────────
# Local: http://localhost:3000
# Production: https://bizflow.id.vn (or your custom domain)
# Used in magic-link / invite emails — MUST match the actual deployment URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_key                             # sensitive
RESEND_FROM_EMAIL=noreply@yourdomain.com               # must be a Resend-verified domain

# ── AI providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key                      # sensitive
OPENAI_API_KEY=sk-proj-your-key                        # sensitive
# AES-256-GCM key for encrypting tenant BYOK API keys in the DB
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: changing this value makes all stored BYOK keys unreadable
AI_KEY_ENCRYPTION_SECRET=64-char-hex-string            # sensitive

# ── Platform admin ────────────────────────────────────────────────────────────
# Email address that can access /platform — must match a real Supabase auth user
PLATFORM_ADMIN_EMAIL=admin@yourdomain.com

# ── Sentry (error monitoring) ────────────────────────────────────────────────
# Get from sentry.io → Project → Settings → Client Keys (DSN)
# NEXT_PUBLIC_ prefix so it's available in the browser for client-side errors
NEXT_PUBLIC_SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
# Optional: upload source maps for readable stack traces in Sentry
# Get from sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=your-auth-token                      # sensitive

# ── Cron (SLA digest & escalation emails) ────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set the same value in Vercel → Project Settings → Cron Jobs (or env vars)
CRON_SECRET=64-char-hex-string                         # sensitive

# ── Dev / testing only (do NOT set in production Vercel) ─────────────────────
TENANT_ISOLATION_TEST_EMAIL=tenant-b-user@example.com
TENANT_ISOLATION_TEST_PASSWORD=test-password
